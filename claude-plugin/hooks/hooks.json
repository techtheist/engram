{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "ENGRAM_HOOK_SOURCE=plugin \"${CLAUDE_PLUGIN_ROOT}\"/hooks/session-brief.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "ENGRAM_HOOK_SOURCE=plugin \"${CLAUDE_PLUGIN_ROOT}\"/hooks/file-read-match.sh"
          }
        ]
      }
    ]
  }
}
